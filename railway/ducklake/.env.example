# =============================================================================
# DuckLake — Variables de entorno
# Copiar a .env y completar con los valores reales:
#   cp .env.example .env
#
# IMPORTANTE: nunca commitear .env al repositorio.
# =============================================================================

# --- Paths (en Railway/Docker usar /app/output; en local usar ./output) ---
OUTPUT_DIR=/app/output
DUCKDB_PATH=/app/output/lake.duckdb

# --- PostgreSQL destino (requerido) ---
PG_HOST=postgres
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=

# --- SFTP fuente (si aplica) ---
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=

# --- Dagster UI (usuario y contraseña de la interfaz web) ---
DAGSTER_USER=admin
DAGSTER_PASSWORD=
